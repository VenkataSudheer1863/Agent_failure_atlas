# Experiment results — keep directory structure, ignore generated files
experiments/results/raw/**/*.jsonl
!experiments/results/raw/**/.gitkeep
experiments/results/metrics/*.json
experiments/results/metrics/*.csv
!experiments/results/metrics/.gitkeep

# Figures (regenerated by analysis scripts)
analysis/results/figures/*.png
analysis/results/figures/*.pdf
!analysis/results/figures/.gitkeep
paper/figures/*.png
paper/figures/*.pdf

# Generated analysis result files (regenerated by analysis scripts)
analysis/results/*.csv
analysis/results/*.json

# Logs
*.log
logs/

# Model weights (never commit these)
*.bin
*.safetensors
*.gguf
*.ggml

# Secrets
.env.local
.env.production
secrets.yaml
