# Agent Failure Atlas — Environment Variables
# Copy this file to .env and fill in your Groq API keys.
# Never commit .env to version control.
# Groq free tier — no credit card required: https://console.groq.com
#
# One key per model allows each model to use its own rate-limit quota.
# Create 6 separate API keys in the Groq console and assign them below.

# ── Model 1: Llama-3.1-8B (llama-3.1-8b-instant) — Small tier ────────────────
GROQ_API_KEY_1=

# ── Model 2: Llama-4-Scout-17B (meta-llama/llama-4-scout-17b-16e-instruct) ────
GROQ_API_KEY_2=

# ── Model 3: Qwen3-32B (qwen/qwen3-32b) — Reasoning tier ─────────────────────
GROQ_API_KEY_3=

# ── Model 4: Llama-3.3-70B (llama-3.3-70b-versatile) — Large tier ─────────────
GROQ_API_KEY_4=

# ── Model 5: GPT-OSS-20B (openai/gpt-oss-20b) — Frontier-20B tier ─────────────
GROQ_API_KEY_5=

# ── Model 6: GPT-OSS-120B (openai/gpt-oss-120b) — Frontier-120B tier ──────────
GROQ_API_KEY_6=
